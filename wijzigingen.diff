+const SETUP_DRAFT_KEY = 'drankEiland.setupDraft.v1';
+let SETUP_DRAFT = null;
+
+function _loadSetupDraftFromStorage() {
+    try {
+        const s = localStorage.getItem(SETUP_DRAFT_KEY);
+        if (!s) return null;
+        const parsed = JSON.parse(s);
+        if (!Array.isArray(parsed) || parsed.length < 2) return null;
+        // Sanitize: kleuren mogen niet botsen, namen moeten string zijn.
+        const used = new Set();
