+            let c = Number.isInteger(p.colorIdx) ? p.colorIdx : i;
+            if (c < 0 || c >= PLAYER_COLORS.length) c = i % PLAYER_COLORS.length;
+            while (used.has(c)) c = (c + 1) % PLAYER_COLORS.length;
+            used.add(c);
+            return {
+                name: (typeof p.name === 'string' && p.name.trim()) ? p.name : `Speler ${i + 1}`,
+                colorIdx: c,
+                avatar: loadAvatarForColor(c),
+            };
+        });
+    } catch (e) { return null; }
+}
+
+function saveSetupDraft() {
+    if (!SETUP_DRAFT) return;
+    try {
+        const slim = SETUP_DRAFT.map(p => ({ name: p.name, colorIdx: p.colorIdx }));
