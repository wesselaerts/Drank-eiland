+/* ─────────────────────────────────────────────
+   7c. MYSTERY WHEEL — bamboo strand-kraam op Bowl Eiland
+   ─────────────────────────────────────────────
+   Een echt 3D draaibord in een bamboe kraam, op het OOSTELIJKE
+   deel van Bowl Eiland. Camera vliegt vanaf oost (zee-kant) naar
+   west zodat Volkaan Eiland in de verte achter het rad zichtbaar
+   is. Het hele apparaat is verborgen tot playMysteryWheel het
+   activeert, en wordt weer onzichtbaar na de minigame.
+
+   Structure:
+     mysteryStall          (Group) — alle bamboe + dak + sign + axle
+     ├─ posts (4×)         vertikale bamboe palen
+     ├─ beams              horizontale dwarsbalken bovenaan
+     ├─ thatched roof      dubbele schuine "rieten" panelen + nokbalk
+     ├─ backboard          paneel achter het rad
+     ├─ counter            bamboe toonbank vooraan
+     ├─ sign               "MYSTERY WHEEL" bord
+     ├─ axle               horizontale as door rad
+     ├─ pointer (vast)     gouden pijl bovenaan, niet draaiend
+     └─ mysteryWheelSpin   (Group) — alleen DIT roteert om wereld-X
+        ├─ disc back       achterkant (donker hout)
+        ├─ rim             rand-cilinder (donker)
+        ├─ disc front      schijf met segment-textuur (rebuilt per opties)
+        ├─ pegs (N×)       kleine cilinders op rim (op segment-randen)
+        └─ hub             gouden naaf met 🌋 emoji
+   ───────────────────────────────────────────── */
+const MWHEEL = {
+    cx:     BOWL.cx + 6,    // 88 — iets oost van bowling-centrum
+    cz:     BOWL.cz,
+    floorY: BOWL.sandTopY,  // staat op het zand, top y=1.05
+    wheelY: 3.35,           // wereld-Y van de as = midden van rad
+    radius: 1.8,
+    thick:  0.18,
+    postH:  4.6,
+    stallW: 5.2,
+    stallD: 3.2,
+    pegRad: 0.07,
+    pegLen: 0.22,
+};
+
+// Module-level state — lazy gebouwd bij eerste playMysteryWheel call.
+let mysteryStall = null;          // outer group (alles)
+let mysteryWheelSpin = null;      // inner group dat roteert om X-as
+let mysteryWheelFaceMeshes = [];  // wedges + labels + pegs — wegooien als opties veranderen
+let mysteryWheelOptionsKey = '';  // cache-sleutel voor opties (vermijd onnodige rebuilds)
+
+/* makeBambooPost — 1 bamboo paal als Group met ringen */
+function makeBambooPost(height) {
+    const g = new THREE.Group();
+    const lightMat = new THREE.MeshToonMaterial({
+        color: 0xd4b06a, gradientMap: toon });
+    const darkMat = new THREE.MeshToonMaterial({
+        color: 0x8a6428, gradientMap: toon });
+    const pole = new THREE.Mesh(
+        new THREE.CylinderGeometry(0.13, 0.15, height, 10), lightMat);
+    pole.position.y = height / 2;
+    pole.castShadow = true;
+    pole.receiveShadow = true;
+    g.add(pole);
+    addOutline(pole, 1.03);
+    const nodes = 5;
+    for (let i = 1; i <= nodes; i++) {
+        const ring = new THREE.Mesh(
+            new THREE.CylinderGeometry(0.16, 0.16, 0.07, 12), darkMat);
+        ring.position.y = (height / (nodes + 1)) * i;
+        g.add(ring);
+    }
+    return g;
+}
+
+/* makeBambooBeam — horizontale balk tussen twee 2D punten (x,z) op hoogte y */
+function makeBambooBeam(x1, z1, x2, z2, y, radius = 0.12) {
+    const dx = x2 - x1, dz = z2 - z1;
+    const len = Math.hypot(dx, dz);
+    const mat = new THREE.MeshToonMaterial({
+        color: 0xc89e58, gradientMap: toon });
+    const m = new THREE.Mesh(
+        new THREE.CylinderGeometry(radius, radius, len, 8), mat);
+    m.castShadow = true;
+    m.position.set((x1 + x2) / 2, y, (z1 + z2) / 2);
+    m.rotation.z = Math.PI / 2;
+    m.rotation.y = -Math.atan2(dz, dx);
+    return m;
+}
+
+/* makeMysterySignTexture — houten bord met "MYSTERY WHEEL" tekst */
+function makeMysterySignTexture() {
+    const W = 1024, H = 256;
+    const c = document.createElement('canvas');
+    c.width = W; c.height = H;
+    const ctx = c.getContext('2d');
+    const grad = ctx.createLinearGradient(0, 0, 0, H);
+    grad.addColorStop(0, '#c89456');
+    grad.addColorStop(1, '#8e6028');
+    ctx.fillStyle = grad;
+    ctx.fillRect(0, 0, W, H);
+    ctx.strokeStyle = '#3a2410';
+    ctx.lineWidth = 14;
+    ctx.strokeRect(7, 7, W - 14, H - 14);
+    // houtnerf
+    ctx.strokeStyle = 'rgba(50,30,10,0.25)';
+    ctx.lineWidth = 2;
+    for (let i = 0; i < 6; i++) {
+        ctx.beginPath();
+        ctx.moveTo(40, 30 + i * 40);
+        ctx.bezierCurveTo(W * 0.3, 20 + i * 40, W * 0.7, 40 + i * 40, W - 40, 30 + i * 40);
+        ctx.stroke();
+    }
+    ctx.font = 'bold 110px system-ui, -apple-system, sans-serif';
+    ctx.textAlign = 'center';
+    ctx.textBaseline = 'middle';
+    ctx.fillStyle = '#fff7e0';
+    ctx.strokeStyle = '#2a1800';
+    ctx.lineWidth = 10;
+    ctx.lineJoin = 'round';
+    ctx.strokeText('🎡 MYSTERY WHEEL', W / 2, H / 2);
+    ctx.fillText('🎡 MYSTERY WHEEL', W / 2, H / 2);
+    const tex = new THREE.CanvasTexture(c);
+    tex.anisotropy = 4;
+    return tex;
+}
+
+/* makeMysteryWheelFaceTexture — tekent het rad-vlak (wedges + labels)
+   op een vierkant canvas dat we als textuur op de front-disc gebruiken.
+
+   CONVENTIES (zie ook winnerIndex):
+   - Canvas (0,0) = links-boven, Y groeit naar BENEDEN.
+   - Het rad wordt op een CircleGeometry gemapd, met mesh.rotation.y=+π/2
+     zodat zijn normaal langs wereld +X (oost, richting camera) wijst.
+   - Daarmee komt canvas TOP (Y=0) overeen met wereld TOP (+Y), en
+     canvas RIGHT (X=W) met viewer's RIGHT (= wereld -Z). Geen mirror.
+   - Segment i is GECENTREERD op canvas hoek α_i = -π/2 + i*segAng
+     en strekt van α_i - segAng/2 tot α_i + segAng/2.
+     (α=-π/2 = canvas TOP; canvas hoek toeneemt = visual CW.)
+   - Bij rotation.x = 0 zit segment 0's CENTRUM dus precies onder de
+     pijl bovenaan.
+*/
+function makeMysteryWheelFaceTexture(options) {
+    const SZ = 1024;
+    const c = document.createElement('canvas');
+    c.width = SZ; c.height = SZ;
+    const ctx = c.getContext('2d');
+    const cx = SZ / 2, cy = SZ / 2;
+    const R  = SZ / 2 - 8;
+    const N  = options.length;
+    const segAng = (Math.PI * 2) / N;
+
+    // achtergrond transparant houden (de back-disc vult de rest)
+    ctx.clearRect(0, 0, SZ, SZ);
+
+    // donkere buitenring achter de segmenten (geeft "ingelegd" gevoel)
+    ctx.beginPath();
+    ctx.arc(cx, cy, R + 4, 0, Math.PI * 2);
+    ctx.fillStyle = '#2a1a08';
+    ctx.fill();
+
+    // ── WEDGES ──
+    for (let i = 0; i < N; i++) {
+        const aMid = -Math.PI / 2 + i * segAng;
+        const aStart = aMid - segAng / 2;
+        const aEnd   = aMid + segAng / 2;
+        ctx.beginPath();
+        ctx.moveTo(cx, cy);
+        ctx.arc(cx, cy, R, aStart, aEnd, false);
+        ctx.closePath();
+        // fill met segment-kleur
+        ctx.fillStyle = options[i].color;
+        ctx.fill();
+        // donkere segmentlijn
+        ctx.strokeStyle = 'rgba(0,0,0,0.55)';
+        ctx.lineWidth = 4;
+        ctx.stroke();
+        // glans-overlay (radiaal naar buiten lichter)
+        const radial = ctx.createRadialGradient(cx, cy, R * 0.15, cx, cy, R);
+        radial.addColorStop(0, 'rgba(255,255,255,0.25)');
+        radial.addColorStop(0.55, 'rgba(255,255,255,0.05)');
+        radial.addColorStop(1, 'rgba(0,0,0,0.18)');
+        ctx.beginPath();
+        ctx.moveTo(cx, cy);
+        ctx.arc(cx, cy, R, aStart, aEnd, false);
+        ctx.closePath();
+        ctx.fillStyle = radial;
+        ctx.fill();
+    }
+
+    // ── LABELS (emoji + tekst, geroteerd zodat het radiaal leest) ──
+    for (let i = 0; i < N; i++) {
+        const aMid = -Math.PI / 2 + i * segAng;
+        const labR = R * 0.62;
+        const lx = cx + labR * Math.cos(aMid);
+        const ly = cy + labR * Math.sin(aMid);
+        ctx.save();
+        ctx.translate(lx, ly);
+        // canvas-rotatie: positieve hoek = visual CW.
+        // We willen dat de tekst van "binnen" naar "buiten" leest, met de
+        // bodem van de letters naar het CENTRUM. Bij segment 0 (top) is
+        // aMid = -π/2; tekst moet horizontaal staan. ctx.rotate(aMid + π/2)
+        // geeft daar 0. Bij segment rechts (aMid = 0) krijgen we π/2 →
+        // tekst leest naar beneden vanaf rechts (= van buiten naar binnen
+        // gelezen, "voor de kijker rechts" tilt-head-rechts). Klassieke
+        // prijzenrad look.
+        ctx.rotate(aMid + Math.PI / 2);
+        ctx.textAlign = 'center';
+        ctx.textBaseline = 'middle';
+        // EMOJI (groter, boven het label)
+        ctx.font = 'bold 72px "Apple Color Emoji", "Segoe UI Emoji", system-ui, sans-serif';
+        ctx.fillStyle = '#ffffff';
+        ctx.strokeStyle = 'rgba(0,0,0,0.85)';
+        ctx.lineWidth = 5;
+        ctx.lineJoin = 'round';
+        // emoji vertikaal iets richting buitenrand
+        ctx.strokeText(options[i].emoji, 0, -R * 0.18);
+        ctx.fillText(options[i].emoji, 0, -R * 0.18);
+        // LABEL TEKST onder de emoji
+        ctx.font = 'bold 34px system-ui, -apple-system, sans-serif';
+        ctx.fillStyle = '#ffffff';
+        ctx.strokeStyle = 'rgba(0,0,0,0.9)';
+        ctx.lineWidth = 6;
+        ctx.strokeText(options[i].label, 0, R * 0.10);
+        ctx.fillText(options[i].label, 0, R * 0.10);
+        ctx.restore();
+    }
+
+    // dunne donkere rand om hele schijf (visuele afsluiting)
+    ctx.beginPath();
+    ctx.arc(cx, cy, R - 2, 0, Math.PI * 2);
+    ctx.strokeStyle = 'rgba(0,0,0,0.55)';
+    ctx.lineWidth = 6;
+    ctx.stroke();
+
+    const tex = new THREE.CanvasTexture(c);
+    tex.anisotropy = 4;
+    return tex;
+}
+
+/* buildMysteryStallOnce — bouwt alle PERMANENTE delen van de kraam
+   (palen, dak, sign, axle, pointer, backboard, counter, achter-disc,
+   rim) één keer. Het rad-vlak (wedges + labels + pegs + hub) wordt
+   los gebouwd door applyMysteryOptionsToWheel(). */
+function buildMysteryStallOnce() {
+    if (mysteryStall) return;
+
+    const stall = new THREE.Group();
+    stall.position.set(MWHEEL.cx, MWHEEL.floorY, MWHEEL.cz);
+    stall.visible = false;
+    scene.add(stall);
+    mysteryStall = stall;
+
+    const halfW = MWHEEL.stallW / 2;
+    const halfD = MWHEEL.stallD / 2;
+    const topY  = MWHEEL.postH;
+
+    // ── 4 hoekpalen ──
+    for (const [px, pz] of [[-halfW, -halfD], [-halfW, halfD],
+                            [ halfW, -halfD], [ halfW,  halfD]]) {
+        const post = makeBambooPost(MWHEEL.postH);
+        post.position.set(px, 0, pz);
+        stall.add(post);
+    }
+
+    // ── Bovenbalken (frame onder dak) ──
+    stall.add(makeBambooBeam(-halfW, -halfD,  halfW, -halfD, topY));   // front (oost)
+    stall.add(makeBambooBeam(-halfW,  halfD,  halfW,  halfD, topY));   // back
+    stall.add(makeBambooBeam(-halfW, -halfD, -halfW,  halfD, topY));   // west zijkant
+    stall.add(makeBambooBeam( halfW, -halfD,  halfW,  halfD, topY));   // oost zijkant
+
+    // ── Schuin "rieten" dak (twee panelen + nokbalk) ──
+    const thatchDarkMat = new THREE.MeshToonMaterial({
+        color: 0x7a5520, gradientMap: toon });
+    const thatchLightMat = new THREE.MeshToonMaterial({
+        color: 0xa68238, gradientMap: toon });
+    const roofGeo = new THREE.BoxGeometry(MWHEEL.stallW + 0.7, 0.14, halfD + 0.35);
+    const roofF = new THREE.Mesh(roofGeo, thatchDarkMat);
+    roofF.position.set(0, topY + 0.62, -halfD * 0.5);
+    roofF.rotation.x = -Math.PI / 7;
+    roofF.castShadow = true;
+    stall.add(roofF);
+    addOutline(roofF, 1.012);
+    const roofB = new THREE.Mesh(roofGeo, thatchDarkMat);
+    roofB.position.set(0, topY + 0.62, halfD * 0.5);
+    roofB.rotation.x = Math.PI / 7;
+    roofB.castShadow = true;
+    stall.add(roofB);
+    addOutline(roofB, 1.012);
+    // Nokbalk
+    const ridge = new THREE.Mesh(
+        new THREE.CylinderGeometry(0.10, 0.10, MWHEEL.stallW + 0.8, 8),
+        new THREE.MeshToonMaterial({ color: 0x5a3f18, gradientMap: toon }));
+    ridge.rotation.z = Math.PI / 2;
+    ridge.position.set(0, topY + 1.05, 0);
+    ridge.castShadow = true;
+    stall.add(ridge);
+    // Lichte riet-strepen
+    for (const zSide of [-1, 1]) {
+        const stripe = new THREE.Mesh(
+            new THREE.BoxGeometry(MWHEEL.stallW + 0.5, 0.05, 0.16),
+            thatchLightMat);
+        stripe.position.set(0, topY + 0.55 + 0.04, zSide * halfD * 0.35);
+        stripe.rotation.x = zSide < 0 ? -Math.PI / 7 : Math.PI / 7;
+        stall.add(stripe);
+    }
+
+    // ── Backboard (paneel achter rad, hangt aan back-palen) ──
+    const backboardMat = new THREE.MeshToonMaterial({
+        color: 0x9a6a2e, gradientMap: toon });
+    const backboard = new THREE.Mesh(
+        new THREE.BoxGeometry(MWHEEL.stallW - 0.6, MWHEEL.postH - 0.8, 0.08),
+        backboardMat);
+    backboard.position.set(0, (MWHEEL.postH - 0.8) / 2 + 0.4, halfD - 0.08);
+    backboard.castShadow = true;
+    backboard.receiveShadow = true;
+    stall.add(backboard);
+    addOutline(backboard, 1.008);
+
+    // ── Counter (bamboe toonbank vóór de kraam) ──
+    const counterMat = new THREE.MeshToonMaterial({
