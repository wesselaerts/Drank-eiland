+                    el('div', { style: { width: '12px', height: '12px',
+                        borderRadius: '50%', background: s.player.color.css } }),
+                    el('div', { style: { flex: '1', fontWeight: '800' } },
+                        `${i+1}. ${s.player.name}`),
+                    el('div', { style: { fontSize: '20px', fontWeight: '900',
+                        color: s.player.color.css } }, String(s.score)),
