+/* ════════════════════════════════════════════════════════════════════
+   3. Krabben Vangen — Whack-a-Mole crabs
+   ════════════════════════════════════════════════════════════════════
+   Per speler 30-seconden run. Krabben spawnen in willekeurige holes,
+   blijven 0.7-1.4s, dan duiken ze weg. Tap = +1 score + zandwolk.
+   Hoogste score wint.
+   ════════════════════════════════════════════════════════════════════ */
+function playKrabbenVangen({ players = G.players, drinks = 2 } = {}) {
+    return new Promise(resolve => {
+        const ui = document.getElementById('game-ui');
+        const back = el('div', { className: 'krab-back' });
+        const head = el('div', { className: 'krab-head' });
+        head.append(el('h2', {}, '🦀 Krabben Vangen'));
+        // HUD
+        const hud = el('div', { className: 'krab-hud' });
+        const pChip = el('div', { className: 'krab-chip' });
+        const pLbl = el('div', { className: 'lbl' }, 'Speler');
+        const pVal = el('div', { className: 'val' }, '–');
+        pChip.append(pLbl, pVal);
+        const tChip = el('div', { className: 'krab-chip' });
+        tChip.append(el('div', { className: 'lbl' }, 'Tijd'));
+        const tVal = el('div', { className: 'val' }, '30');
+        tChip.append(tVal);
+        const sChip = el('div', { className: 'krab-chip' });
+        sChip.append(el('div', { className: 'lbl' }, 'Score'));
+        const sVal = el('div', { className: 'val' }, '0');
+        sChip.append(sVal);
+        hud.append(pChip, tChip, sChip);
+        // Stage
+        const stage = el('div', { className: 'krab-stage' });
+        back.append(head, hud, stage);
+        ui.append(back);
+
+        // ── STATE ──
+        const ROUND_MS = 30000;
+        const HOLES = 8;           // aantal gaten
+        const holes = [];          // {x, y, busy, el}
+        const scores = [];         // {player, score}
+        let curIdx = 0;
+        let score = 0;
+        let phase = 'intro';       // intro | playing | done
+        let phaseStart = 0;
+        let crabSpawnTimer = 0;
+        let crabSpawnInterval = 0.55;
+        const activeCrabs = [];    // {hole, el, expireAt}
+
+        // Plaats gaten in een patroon (verspreid maar niet recht-toe-recht-aan)
+        function layoutHoles() {
+            const w = stage.clientWidth, h = stage.clientHeight;
+            const gx = [0.20, 0.50, 0.80, 0.30, 0.70, 0.20, 0.50, 0.80];
+            const gy = [0.18, 0.18, 0.18, 0.45, 0.45, 0.72, 0.72, 0.72];
+            holes.length = 0;
+            // verwijder oude
+            stage.querySelectorAll('.krab-hole').forEach(e => e.remove());
+            for (let i = 0; i < HOLES; i++) {
+                const hx = gx[i] * w, hy = gy[i] * h;
+                const hole = el('div', { className: 'krab-hole',
+                    style: { left: hx + 'px', top: hy + 'px' } });
+                stage.append(hole);
+                holes.push({ x: hx, y: hy, busy: false, el: hole });
+            }
+        }
+        function spawnCrab() {
+            // Random vrij gat kiezen
+            const free = holes.filter(h => !h.busy);
+            if (free.length === 0) return;
+            const hole = free[Math.floor(Math.random() * free.length)];
+            hole.busy = true;
+            const crab = el('div', { className: 'krab-crab',
+                style: { left: hole.x + 'px', top: hole.y + 'px' } }, '🦀');
+            stage.append(crab);
+            requestAnimationFrame(() => crab.classList.add('show'));
+            // expire na random tijd
+            const lifeMs = 700 + Math.random() * 700;
+            const obj = { hole, el: crab, expireAt: performance.now() + lifeMs, hit: false };
+            activeCrabs.push(obj);
+            crab.addEventListener('touchstart', e => { e.preventDefault(); onHit(obj); },
+                { passive: false });
+            crab.addEventListener('mousedown', e => onHit(obj));
+        }
+        function onHit(c) {
+            if (c.hit || phase !== 'playing') return;
+            c.hit = true;
+            score++;
+            sVal.textContent = String(score);
+            c.el.classList.add('hit');
+            // Zandwolk
+            const dust = el('div', { className: 'krab-dust',
+                style: { left: c.hole.x + 'px', top: c.hole.y + 'px' } });
+            stage.append(dust);
+            setTimeout(() => dust.remove(), 600);
+            // Krab verdwijnt sneller
+            setTimeout(() => {
+                c.el.remove(); c.hole.busy = false;
+                const idx = activeCrabs.indexOf(c);
+                if (idx >= 0) activeCrabs.splice(idx, 1);
+            }, 350);
+        }
+        function expireCrab(c) {
+            c.el.classList.remove('show');
+            setTimeout(() => {
+                c.el.remove(); c.hole.busy = false;
+                const idx = activeCrabs.indexOf(c);
+                if (idx >= 0) activeCrabs.splice(idx, 1);
+            }, 200);
+        }
+        function startRun(playerIdx) {
+            curIdx = playerIdx;
+            const p = players[curIdx];
+            pVal.textContent = p.name;
+            pVal.style.color = p.color.css;
+            pChip.style.setProperty('--pcol', p.color.css);
+            sVal.textContent = '0';
+            score = 0;
+            // Cleanup old crabs/holes
+            activeCrabs.forEach(c => c.el.remove());
+            activeCrabs.length = 0;
+            holes.forEach(h => h.busy = false);
+            // Banner
+            const banner = el('div', { className: 'krab-banner',
+                style: { '--pcol': p.color.css } });
+            banner.append(
+                el('h2', { style: { color: p.color.css } }, `${p.name}`),
+                el('p', {}, 'Tik zoveel mogelijk krabben in 30 seconden'),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => {
+                        banner.remove();
+                        phase = 'playing';
+                        phaseStart = performance.now();
+                        crabSpawnTimer = 0;
+                        if (!holes.length) layoutHoles();
+                    }} }, '▶ Start'),
+            );
+            stage.append(banner);
+            phase = 'intro';
+        }
+        function endRun() {
+            phase = 'between';
+            scores.push({ player: players[curIdx], score });
+            activeCrabs.forEach(c => c.el.remove());
+            activeCrabs.length = 0;
+            holes.forEach(h => h.busy = false);
+            const p = players[curIdx];
+            const banner = el('div', { className: 'krab-banner',
+                style: { '--pcol': p.color.css } });
+            banner.append(
+                el('h2', {}, 'Klaar!'),
+                el('div', { className: 'big', style: { color: p.color.css } }, String(score)),
+                el('p', {}, `krabben gevangen door ${p.name}`),
+            );
+            stage.append(banner);
+            setTimeout(() => {
+                banner.remove();
+                if (curIdx < players.length - 1) startRun(curIdx + 1);
+                else showFinal();
+            }, 2200);
+        }
+        function showFinal() {
+            phase = 'done';
+            const sorted = [...scores].sort((a, b) => b.score - a.score);
+            const topS = sorted[0].score;
+            const winners = sorted.filter(s => s.score === topS);
+            const losers = sorted.filter(s => s.score < topS);
+            const winName = winners.map(w => w.player.name).join(' & ');
+            const banner = el('div', { className: 'krab-banner',
+                style: { '--pcol': winners[0].player.color.css } });
+            const ranking = el('div', { style: {
+                margin: '12px 0', display: 'flex', flexDirection: 'column', gap: '6px' } });
+            sorted.forEach((s, i) => {
+                ranking.append(el('div', { style: {
+                    display: 'flex', justifyContent: 'space-between', gap: '12px',
+                    padding: '6px 12px', borderRadius: '8px',
+                    background: 'rgba(255,255,255,0.08)',
+                    border: '1px solid ' + s.player.color.css,
+                    opacity: s.score === topS ? '1' : '0.65' } },
+                    el('span', {}, `${i+1}. ${s.player.name}`),
+                    el('span', { style: { color: s.player.color.css, fontWeight: '900' } },
+                        String(s.score)),
+                ));
+            });
+            banner.append(
+                el('h2', {}, '🏆 Eindstand'),
+                ranking,
+                el('p', {}, losers.length === 0 ? 'Gelijkspel — proost!' :
+                    `${losers.map(l => l.player.name).join(', ')} drinkt elk ${drinks} 🍻`),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => finish(sorted) } }, 'Klaar'),
+            );
+            stage.append(banner);
+            setTimeout(() => finish(sorted), 8000);
+        }
+        function finish(sorted) {
+            if (phase === 'closed') return;
+            phase = 'closed';
+            cancelAnimationFrame(rafId);
+            back.style.transition = 'opacity 0.3s ease';
+            back.style.opacity = '0';
+            setTimeout(() => { back.remove(); resolve(sorted || null); }, 300);
+        }
+
+        let rafId = 0, lastT = 0;
+        function tick(t) {
+            const dt = lastT ? (t - lastT) / 1000 : 0;
+            lastT = t;
+            if (phase === 'playing') {
+                const elapsed = performance.now() - phaseStart;
+                const remaining = Math.max(0, ROUND_MS - elapsed);
+                tVal.textContent = Math.ceil(remaining / 1000).toString();
+                // Spawn ritme versnelt: 0.55s → 0.30s
+                const t01 = elapsed / ROUND_MS;
+                crabSpawnInterval = 0.55 - t01 * 0.25;
+                crabSpawnTimer += dt;
+                if (crabSpawnTimer >= crabSpawnInterval) {
+                    crabSpawnTimer -= crabSpawnInterval;
+                    spawnCrab();
+                }
+                // Expire crabs
+                const now = performance.now();
+                for (let i = activeCrabs.length - 1; i >= 0; i--) {
+                    if (!activeCrabs[i].hit && now >= activeCrabs[i].expireAt) {
+                        expireCrab(activeCrabs[i]);
+                    }
+                }
+                if (elapsed >= ROUND_MS) endRun();
+            }
+            rafId = requestAnimationFrame(tick);
+        }
+        // Wacht tot stage layout heeft, dan starten
+        setTimeout(() => {
+            layoutHoles();
+            window.addEventListener('resize', () => layoutHoles());
+            startRun(0);
+            rafId = requestAnimationFrame(tick);
+        }, 50);
+    });
+}
