+/* ============================================================
+   hideMinigameChrome / restoreMinigameChrome
+   ============================================================
+   Tijdens een minigame willen we al het bord-game UI rommel
+   verstoppen: home-knop, top-bar (titel+ronde), mini-map (rechts-
+   boven), en de bottom-hud (speler-kaart + dobbelsteen). Plus de
+   home-scherm overlay (.screen) op de minigame-tab.
+
+   Zonder dit hangt er bv. een dobbelsteen-icoon midden over een
+   raft-battle of bowling-scoreboard heen — niet wat we willen.
+
+   Returns een array met {el, prev} entries die je aan
+   restoreMinigameChrome doorgeeft als de minigame klaar is.
+   ============================================================ */
+function hideMinigameChrome() {
+    const hidden = [];
+    // Bord-game chrome
+    for (const id of ['home-btn', 'top-bar', 'minimap', 'hud']) {
+        const e = document.getElementById(id);
+        if (e) {
+            hidden.push({ el: e, prev: e.style.display });
+            e.style.display = 'none';
+        }
+    }
+    // Home-scherm overlay (alleen actief op de minigame-tab)
+    document.querySelectorAll('#game-ui > .screen').forEach(s => {
+        hidden.push({ el: s, prev: s.style.display });
+        s.style.display = 'none';
+    });
+    return hidden;
+}
+function restoreMinigameChrome(hidden) {
+    if (!hidden) return;
+    for (const h of hidden) {
+        if (h.el && h.el.style) h.el.style.display = h.prev;
+    }
+}
