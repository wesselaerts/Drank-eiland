+    { name:'Bm', root: 123.47,       notes: [D_MAJOR.B3,  D_MAJOR.D4,  D_MAJOR.Fs4] },
+    { name:'G',  root:  98.00,       notes: [D_MAJOR.G3,  D_MAJOR.B3,  D_MAJOR.D4 ] },
