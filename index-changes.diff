+    { freq: D_MAJOR.D3,  weight: 5 },   // ding (tonic)
+    { freq: D_MAJOR.A3,  weight: 5 },   // dominant kwint
+    { freq: D_MAJOR.Fs3, weight: 4 },   // grote terts (vrolijk)
+    { freq: D_MAJOR.D4,  weight: 3 },   // tonic octaaf
+    { freq: D_MAJOR.Fs4, weight: 3 },   // hoge terts (helder)
+    { freq: D_MAJOR.E4,  weight: 2 },
+    { freq: D_MAJOR.B3,  weight: 2 },   // grote sext
+    { freq: D_MAJOR.A4,  weight: 2 },
+    { freq: D_MAJOR.G3,  weight: 1 },   // kwart (modaal kleur)
+    { freq: D_MAJOR.Cs4, weight: 1 },   // leading tone (sparkle)
