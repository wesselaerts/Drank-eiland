+            drag.active = false;
+            power.style.display = 'none';
+            aimArrow.visible = false;
+            if (phase !== 'aiming') return;
+            const rel = computeReleaseParams();
+            // Vereist een echte upward swipe — anders annuleer
+            if (rel.dy < 35 || rel.swipeSpeed < 180) {
