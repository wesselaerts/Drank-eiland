+/* ════════════════════════════════════════════════════════════════════
+   5. Brug Balans — gyroscoop balanceer-game
+   ════════════════════════════════════════════════════════════════════
+   Personage loopt automatisch over een brug. Telefoon-tilt (gamma) →
+   helling van het personage. Buiten threshold = val in lava.
+   Survival-time = score. Hoogste wint.
+   ════════════════════════════════════════════════════════════════════ */
+function playBrugBalans({ players = G.players, drinks = 3 } = {}) {
+    return new Promise(resolve => {
+        const ui = document.getElementById('game-ui');
+        const back = el('div', { className: 'brug-back' });
+        const head = el('div', { className: 'brug-head' });
+        head.append(el('h2', {}, '⚖️ Brug Balans'));
+        const hud = el('div', { className: 'brug-hud' });
+        const pChip = el('div', { className: 'tiki-chip' });
+        pChip.append(el('div', { className: 'lbl' }, 'Speler'));
+        const pVal = el('div', { className: 'val' }, '–');
+        pChip.append(pVal);
+        const sChip = el('div', { className: 'tiki-chip' });
+        sChip.append(el('div', { className: 'lbl' }, 'Tijd'));
+        const sVal = el('div', { className: 'val' }, '0.0s');
+        sChip.append(sVal);
+        hud.append(pChip, sChip);
+        const stage = el('div', { className: 'brug-stage' });
+        const bridge = el('div', { className: 'brug-bridge' });
+        const char = el('div', { className: 'brug-char' }, '🧗');
+        const meter = el('div', { className: 'brug-tilt-meter' });
+        const center = el('div', { className: 'center' });
+        const pin = el('div', { className: 'pin' });
+        meter.append(center, pin);
+        stage.append(bridge, char, meter);
+        back.append(head, hud, stage);
+        ui.append(back);
+
+        // ── STATE ──
+        const RUN_MAX_MS = 45000;       // hard cap zodat het nooit oneindig duurt
+        const THRESHOLD = 45;           // graden tilt → val
+        const scores = [];              // {player, time}
+        let curIdx = 0;
+        let phase = 'permission';       // permission | ready | running | failed | between | done
+        let gamma = 0;                  // huidige tilt (left-right)
+        let leanAngle = 0;              // werkelijke karakter-helling (gladgemaakt)
+        let runStart = 0;
+        let lastEvent = 0;
+        let rafId = 0;
+
+        // ── DeviceOrientation ──
+        function onOrient(e) {
+            // gamma: left-right tilt, -90 → 90
+            if (e.gamma != null) {
+                gamma = Math.max(-90, Math.min(90, e.gamma));
+                lastEvent = performance.now();
+            }
+        }
+        async function requestGyroPermission() {
+            // iOS Safari 13+: requestPermission() vereist user-gesture
+            if (typeof DeviceOrientationEvent !== 'undefined' &&
+                typeof DeviceOrientationEvent.requestPermission === 'function') {
+                try {
+                    const res = await DeviceOrientationEvent.requestPermission();
+                    if (res === 'granted') {
+                        window.addEventListener('deviceorientation', onOrient);
+                        return true;
+                    }
+                    return false;
+                } catch (e) { return false; }
+            } else {
+                window.addEventListener('deviceorientation', onOrient);
+                return true;
+            }
+        }
+        function showPermission() {
+            const card = el('div', { className: 'brug-perm' });
+            card.append(
+                el('h3', {}, '📱 Telefoon-sensor nodig'),
+                el('p', {}, 'Brug Balans gebruikt de gyroscoop. Geef toestemming om door te gaan.'),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    on: { click: async () => {
+                        const ok = await requestGyroPermission();
+                        card.remove();
+                        if (ok) {
+                            phase = 'ready';
+                            startRun(0);
+                        } else {
+                            // Geen permissie → skip
+                            const c2 = el('div', { className: 'brug-perm' });
+                            c2.append(
+                                el('h3', {}, '⚠️ Geen toestemming'),
+                                el('p', {}, 'Geen sensor-toegang. Minigame overgeslagen.'),
+                                el('button', { className: 'btn-pill', type: 'button',
+                                    on: { click: () => finish(null) } }, 'OK'),
+                            );
+                            stage.append(c2);
+                        }
+                    }} }, '✓ Toestaan'),
+                el('button', { className: 'btn-pill', type: 'button',
+                    on: { click: () => finish(null) } }, 'Skip'),
+            );
+            stage.append(card);
+        }
+        function startRun(i) {
+            curIdx = i;
+            const p = players[curIdx];
+            pVal.textContent = p.name;
+            pVal.style.color = p.color.css;
+            pChip.style.setProperty('--pcol', p.color.css);
+            sChip.style.setProperty('--pcol', p.color.css);
+            // Reset character
+            char.style.transform = 'translate(-50%, -50%) rotate(0deg)';
+            char.style.left = '50%';
+            char.style.opacity = '1';
+            leanAngle = 0;
+            // Banner
+            const banner = el('div', { className: 'brug-banner',
+                style: { '--pcol': p.color.css } });
+            banner.append(
+                el('h2', { style: { color: p.color.css } }, `${p.name}`),
+                el('p', {}, 'Houd je telefoon zo recht mogelijk om de brug te overleven'),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => {
+                        banner.remove();
+                        phase = 'running';
+                        runStart = performance.now();
+                        lastEvent = performance.now();
+                    }} }, '▶ Start'),
+            );
+            stage.append(banner);
+            phase = 'ready';
+        }
+        function endRun(survivedMs) {
+            phase = 'between';
+            scores.push({ player: players[curIdx], time: survivedMs });
+            // Visual fail
+            char.style.transition = 'all 0.6s ease-in';
+            char.style.transform = `translate(-50%, 220%) rotate(${gamma > 0 ? 90 : -90}deg)`;
+            char.style.opacity = '0';
+            const p = players[curIdx];
+            setTimeout(() => {
+                const banner = el('div', { className: 'brug-banner',
+                    style: { '--pcol': p.color.css } });
+                banner.append(
+                    el('h2', {}, 'Gevallen!'),
+                    el('div', { className: 'big', style: { color: p.color.css } },
+                        (survivedMs / 1000).toFixed(1) + 's'),
+                    el('p', {}, `${p.name} overleefde`),
+                );
+                stage.append(banner);
+                setTimeout(() => {
+                    banner.remove();
+                    char.style.transition = '';
+                    if (curIdx < players.length - 1) startRun(curIdx + 1);
+                    else showFinal();
+                }, 2000);
+            }, 600);
+        }
+        function showFinal() {
+            phase = 'done';
+            const sorted = [...scores].sort((a, b) => b.time - a.time);
+            const topT = sorted[0].time;
+            const losers = sorted.filter(s => s.time < topT);
+            const banner = el('div', { className: 'brug-banner',
+                style: { '--pcol': sorted[0].player.color.css } });
+            const ranking = el('div', { style: {
+                margin: '12px 0', display: 'flex', flexDirection: 'column', gap: '6px' } });
+            sorted.forEach((s, i) => {
+                ranking.append(el('div', { style: {
+                    display: 'flex', justifyContent: 'space-between', gap: '12px',
+                    padding: '6px 12px', borderRadius: '8px',
+                    background: 'rgba(255,255,255,0.08)',
+                    border: '1px solid ' + s.player.color.css,
+                    opacity: s.time === topT ? '1' : '0.65' } },
+                    el('span', {}, `${i+1}. ${s.player.name}`),
+                    el('span', { style: { color: s.player.color.css, fontWeight: '900' } },
+                        (s.time/1000).toFixed(1) + 's'),
+                ));
+            });
+            banner.append(
+                el('h2', {}, '🏆 Eindstand'),
+                ranking,
+                el('p', {}, losers.length === 0 ? 'Gelijkspel — proost!' :
+                    `${losers.map(l => l.player.name).join(', ')} drinkt elk ${drinks} 🍻`),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => finish(sorted) } }, 'Klaar'),
+            );
+            stage.append(banner);
+            setTimeout(() => finish(sorted), 9000);
+        }
+        function finish(sorted) {
+            if (phase === 'closed') return;
+            phase = 'closed';
+            cancelAnimationFrame(rafId);
+            window.removeEventListener('deviceorientation', onOrient);
+            back.style.transition = 'opacity 0.3s ease';
+            back.style.opacity = '0';
+            setTimeout(() => { back.remove(); resolve(sorted || null); }, 300);
+        }
+
+        function tick() {
+            rafId = requestAnimationFrame(tick);
+            if (phase !== 'running') return;
+            // Smooth lean naar gamma
+            leanAngle += (gamma - leanAngle) * 0.25;
+            // Pin in meter (gamma -45..45 → 0..100%)
+            const pinPct = Math.max(0, Math.min(100, (gamma + THRESHOLD) / (2*THRESHOLD) * 100));
+            pin.style.left = pinPct + '%';
+            // Karakter rotatie + lichte horizontale wankel
+            const lean = Math.max(-THRESHOLD * 1.2, Math.min(THRESHOLD * 1.2, leanAngle));
+            const xOff = (lean / THRESHOLD) * 40;     // ±40px
+            char.style.transform =
+                `translate(calc(-50% + ${xOff}px), -50%) rotate(${lean.toFixed(1)}deg)`;
+            // Tijd
+            const elapsed = performance.now() - runStart;
+            sVal.textContent = (elapsed / 1000).toFixed(1) + 's';
+            // Check fail
+            if (Math.abs(leanAngle) >= THRESHOLD || elapsed >= RUN_MAX_MS) {
+                phase = 'failed';
+                endRun(elapsed);
+            }
+            // Geen orientation events in 2 seconden? device draait misschien niet
+            if (performance.now() - lastEvent > 2000 && elapsed > 1000) {
+                // Negeer — kan gewoon stil houden zijn (ok)
+            }
+        }
+        rafId = requestAnimationFrame(tick);
+        showPermission();
+    });
+}
