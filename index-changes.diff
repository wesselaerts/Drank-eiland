+            const winners = sorted.filter(s => s.score === topS);
+            const losers = sorted.filter(s => s.score < topS);
+            const winnerName = winners.map(w => w.player.name).join(' & ');
+            setBanner(`🏆 ${winnerName} wint!`, sorted[0].player.color.css);
+            const ko = el('div', { className: 'rb3-ko',
+                style: { '--pcol': sorted[0].player.color.css } });
+            ko.append(el('h2', {}, '🎳 Eindstand'));
+            const list = el('div', {
+                style: { display: 'flex', flexDirection: 'column', gap: '8px',
+                    margin: '12px 0', width: '100%', maxWidth: '320px' } });
+            sorted.forEach((s, i) => {
+                const row = el('div', {
+                    style: { display: 'flex', alignItems: 'center', gap: '10px',
+                        padding: '8px 12px', borderRadius: '12px',
+                        background: 'rgba(255,255,255,0.10)',
+                        border: '2px solid ' + s.player.color.css,
