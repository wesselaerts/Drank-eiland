+/* ════════════════════════════════════════════════════════════════════
+   2. De Kano Race — split-screen tap race
+   ════════════════════════════════════════════════════════════════════
+   Top helft = playerA, bot helft = playerB. Tap = velocity boost.
+   Velocity decays (water friction). Position += velocity * dt.
+   Winnaar = eerste die finish bereikt.
+   ════════════════════════════════════════════════════════════════════ */
+function playKanoRace({ playerA, playerB, drinks = 4 } = {}) {
+    return new Promise(resolve => {
+        const ui = document.getElementById('game-ui');
+        const back = el('div', { className: 'kano-back' });
+        // Zone bouwen helper
+        function buildZone(player, klass) {
+            const z = el('div', { className: 'kano-zone ' + klass });
+            const island = el('div', { className: 'kano-island' });
+            const finish = el('div', { className: 'kano-finish' });
+            const boat = el('div', { className: 'kano-boat', 'data-c': '1' });
+            boat.style.setProperty('--bcol', player.color.css);
+            const name = el('div', { className: 'kano-name' }, player.name);
+            name.style.setProperty('--pcol', player.color.css);
+            const taps = el('div', { className: 'kano-taps' }, 'TAP!');
+            const prog = el('div', { className: 'kano-progress' });
+            const progBar = el('div');
+            prog.append(progBar);
+            progBar.parentElement.style.setProperty('--pcol', player.color.css);
+            z.append(island, finish, boat, name, taps, prog);
+            return { zone: z, boat, progBar };
+        }
+        const A = buildZone(playerA, 'top');
+        const B = buildZone(playerB, 'bot');
+        back.append(A.zone, B.zone);
+        // Overlay
+        const overlay = el('div', { className: 'kano-overlay show' });
+        const oTitle = el('h2', {}, '🛶 Kano Race');
+        const oText = el('p', {}, `${playerA.name} (boven) vs ${playerB.name} (onder). Tik zo snel mogelijk op JOUW helft! Eerste bij de finish wint.`);
+        const oBtn = el('button', { className: 'btn-pill gold' }, '▶ Start');
+        const oSkip = el('button', { className: 'btn-pill' }, 'Skip');
+        overlay.append(oTitle, oText, oBtn, oSkip);
+        back.append(overlay);
+        ui.append(back);
+
+        // ── STATE ──
+        // pos = 0 (start) → 1 (finish). vel in pos-units/sec.
+        // Eindzone: finish ligt op top:60px, kano start op bottom:80px.
+        // We mappen pos:0 = bottom:80px en pos:1 = bottom: (zoneHeight - 100px) ~ finish.
+        const state = {
+            posA: 0, velA: 0, posB: 0, velB: 0,
+            running: false, finished: false,
+        };
+        const TAP_BOOST = 0.060;     // 6% van afstand per tap (op vel)
+        const FRICTION  = 0.985;     // exponentiele decay per ms (subtiel)
+        const TAP_DECAY_MS = 16.67;
+        let lastT = 0;
+        let rafId = 0;
+        let tapsA = 0, tapsB = 0;
+
+        function updateVisual() {
+            const aH = A.zone.clientHeight;
+            const bH = B.zone.clientHeight;
+            // Bot edge gaat van 80px (start) tot aH-90 (finish near top)
+            // Maar A is geroteerd 180°, dus voor A werkt het visueel hetzelfde:
+            // we zetten gewoon style.bottom op de boat.
+            const aBot = 80 + (aH - 170) * state.posA;
+            const bBot = 80 + (bH - 170) * state.posB;
+            A.boat.style.bottom = aBot + 'px';
+            B.boat.style.bottom = bBot + 'px';
+            A.progBar.style.width = (state.posA * 100).toFixed(1) + '%';
+            B.progBar.style.width = (state.posB * 100).toFixed(1) + '%';
+        }
+        function tick(t) {
+            if (!state.running) return;
+            const dt = lastT ? Math.min(0.05, (t - lastT) / 1000) : 0;
+            lastT = t;
+            // Friction (exponential)
+            const friFac = Math.pow(FRICTION, dt * 60);
+            state.velA *= friFac;
+            state.velB *= friFac;
+            // Apply velocity to position
+            state.posA = Math.min(1, state.posA + state.velA * dt);
+            state.posB = Math.min(1, state.posB + state.velB * dt);
+            updateVisual();
+            // Win conditie
+            const aDone = state.posA >= 1;
+            const bDone = state.posB >= 1;
+            if (aDone || bDone) {
+                state.finished = true;
+                state.running = false;
+                let winner, loser;
+                if (aDone && bDone) {
+                    // gelijkstand — degene met meeste taps wint? gebruik posA/posB extra
+                    winner = tapsA >= tapsB ? playerA : playerB;
+                    loser  = winner === playerA ? playerB : playerA;
+                } else {
+                    winner = aDone ? playerA : playerB;
+                    loser  = aDone ? playerB : playerA;
+                }
+                showResult(winner, loser);
+                return;
+            }
+            rafId = requestAnimationFrame(tick);
+        }
+        function showResult(winner, loser) {
+            overlay.classList.add('show');
+            overlay.replaceChildren(
+                el('h2', { style: { color: winner.color.css } }, `🏆 ${winner.name} wint!`),
+                el('p', {}, `${loser.name} drinkt ${drinks} slokken 🍻`),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    on: { click: () => finish(loser) } }, 'Klaar'),
+            );
+            setTimeout(() => finish(loser), 5000);
+        }
+        function finish(loser) {
+            if (state.finished === 'closed') return;
+            state.finished = 'closed';
+            state.running = false;
+            cancelAnimationFrame(rafId);
+            back.style.transition = 'opacity 0.3s ease';
+            back.style.opacity = '0';
+            setTimeout(() => { back.remove(); resolve(loser); }, 300);
+        }
+
+        // ── INPUT: tap-zones gescheiden ──
+        function onTapA(e) { e.preventDefault(); if (!state.running) return;
+            state.velA += TAP_BOOST; tapsA++; pulseBoat(A.boat); }
+        function onTapB(e) { e.preventDefault(); if (!state.running) return;
+            state.velB += TAP_BOOST; tapsB++; pulseBoat(B.boat); }
+        function pulseBoat(b) {
+            const cur = b.style.transform || 'translateX(-50%)';
+            b.style.transform = 'translateX(-50%) scale(1.05)';
+            setTimeout(() => { b.style.transform = ''; }, 60);
+        }
+        A.zone.addEventListener('touchstart', onTapA, { passive: false });
+        B.zone.addEventListener('touchstart', onTapB, { passive: false });
+        A.zone.addEventListener('mousedown', onTapA);
+        B.zone.addEventListener('mousedown', onTapB);
+
+        oBtn.addEventListener('click', () => {
+            overlay.classList.remove('show');
+            state.running = true;
+            lastT = 0;
+            rafId = requestAnimationFrame(tick);
+        });
+        oSkip.addEventListener('click', () => finish(null));
+        updateVisual();
+    });
+}
