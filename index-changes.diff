+            const isGutter = downCount === 0 && ballPhysics && ballPhysics.inGutter;
+            // Visuele celebration in plaats van alleen toast
+            if (isStrike) {
+                showResultText('STRIKE!', 'strike');
+                spawnConfetti(140);
+            } else if (downCount >= 7) {
+                showResultText('GAAF!', '');
+                spawnConfetti(40);
+            } else if (downCount >= 4) {
+                showResultText(downCount + ' DOWN', '');
+            } else if (isGutter) {
+                showResultText('GUTTER!', 'gutter');
+            } else if (downCount === 0) {
+                showResultText('MIS!', 'gutter');
+            } else {
+                showResultText(downCount + ' DOWN', '');
