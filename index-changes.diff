+    const partials = [
+        { ratio: 1.00, amp: 1.00, decay: 12.0 },
+        { ratio: 2.00, amp: 0.55, decay:  8.0 },
+        { ratio: 3.00, amp: 0.30, decay:  5.0 },
+    ];
+    const baseAmp = 0.024 * velocity;
+
+    for (const p of partials) {
+        const osc = ctx.createOscillator();
+        osc.type = 'sine';
+        osc.frequency.value = fundamental * p.ratio;
+        osc.detune.value = (Math.random() - 0.5) * 4;
+
+        const g = ctx.createGain();
+        g.gain.setValueAtTime(0, time);
+        g.gain.linearRampToValueAtTime(baseAmp * p.amp, time + 0.005);
+        g.gain.exponentialRampToValueAtTime(0.0001, time + p.decay);
+
+        osc.connect(g);
+        g.connect(dest);
+        osc.start(time);
+        osc.stop(time + p.decay + 0.2);
+    }
