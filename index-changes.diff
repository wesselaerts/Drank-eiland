+// ── Background music: toggle button + volume slider (long-press) ──
+(() => {
+    const btn = el('button', { id: 'bg-music-toggle', type: 'button' });
+    btn.textContent = '🔇';
+    document.body.appendChild(btn);
+
+    // Voorkeuren uit localStorage
+    let pref = '1';
+    let savedVol = '0.060';   // standaard laag (lager dan default 0.085)
+    try {
+        pref = localStorage.getItem('bgmusic') ?? '1';
+        savedVol = localStorage.getItem('bgmusic_vol');
+    } catch (e) {}
+    if (savedVol !== null) {
+        const v = parseFloat(savedVol);
+        if (!isNaN(v)) bgMusic.volume = Math.max(0, Math.min(0.20, v));
+    } else {
+        bgMusic.volume = 0.060;   // default laag
+    }
+
+    // ── Long-press detection: tap = toggle, lang ingedrukt = slider ──
+    let pressTimer = null;
+    let didLongPress = false;
+    const LONG_PRESS_MS = 450;
+
+    btn.addEventListener('pointerdown', (e) => {
+        didLongPress = false;
+        pressTimer = setTimeout(() => {
+            pressTimer = null;
+            didLongPress = true;
+            bgMusicShowVolumeSlider();
+        }, LONG_PRESS_MS);
+    });
+    const cancelPress = () => {
+        if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
+    };
+    btn.addEventListener('pointerup', (e) => {
+        if (pressTimer) {
+            clearTimeout(pressTimer);
+            pressTimer = null;
+            // Korte tap → toggle
+            bgMusicToggle();
+        }
+    });
+    btn.addEventListener('pointercancel', cancelPress);
+    btn.addEventListener('pointerleave', cancelPress);
+
+    // Auto-start bij eerste user-interactie als voorkeur 'aan' staat
+    if (pref === '1') {
+        const onFirstInteract = () => {
+            bgMusicStart();
+            window.removeEventListener('pointerdown', onFirstInteract);
+            window.removeEventListener('keydown', onFirstInteract);
+        };
+        window.addEventListener('pointerdown', onFirstInteract);
+        window.addEventListener('keydown', onFirstInteract);
+    }
+    bgMusicSyncToggleVisual();
+})();
+
+// ── Volume slider overlay ──
+// Verschijnt onder de muziek-knop bij long-press. Vertikale slider
+// 0..max(0.20) → past direct master gain aan en saved.
+function bgMusicShowVolumeSlider() {
+    // Sluit als al open
+    const existing = document.getElementById('bg-vol-card');
+    if (existing) { existing.remove(); return; }
+
+    const card = el('div', { id: 'bg-vol-card' });
+    card.append(el('div', { style: { fontSize: '20px', textAlign: 'center' } }, '🎚️'));
+    const bar = el('div', { className: 'bg-vol-bar' });
+    const fill = el('div', { className: 'bg-vol-fill' });
+    bar.append(fill);
+    const pct = el('div', { className: 'bg-vol-pct' });
+    card.append(bar, pct);
+    document.body.appendChild(card);
+
+    const VMAX = 0.20;
+    function setFill() {
+        const ratio = bgMusic.volume / VMAX;
+        fill.style.height = (ratio * 100) + '%';
+        pct.textContent = Math.round(ratio * 100) + '%';
+    }
+    setFill();
+
+    // Sleep-handlers (top = max, bottom = 0)
+    let dragging = false;
+    function updateFromEvent(e) {
+        const rect = bar.getBoundingClientRect();
+        const y = e.clientY - rect.top;
+        const ratio = 1 - Math.max(0, Math.min(1, y / rect.height));
+        bgMusicSetVolume(ratio * VMAX);
+        setFill();
+    }
+    bar.addEventListener('pointerdown', (e) => {
+        dragging = true;
+        bar.setPointerCapture(e.pointerId);
+        updateFromEvent(e);
+    });
+    bar.addEventListener('pointermove', (e) => {
+        if (dragging) updateFromEvent(e);
+    });
+    bar.addEventListener('pointerup', () => { dragging = false; });
+    bar.addEventListener('pointercancel', () => { dragging = false; });
+
+    // Tap buiten de card → sluit
+    setTimeout(() => {
+        const outsideHandler = (e) => {
+            if (!card.contains(e.target) &&
+                e.target.id !== 'bg-music-toggle') {
+                card.remove();
+                document.removeEventListener('pointerdown', outsideHandler);
+            }
+        };
+        document.addEventListener('pointerdown', outsideHandler);
+    }, 50);
+
+    // Auto-close na 6 sec inactiviteit
+    let autoCloseTimer = setTimeout(() => card.remove(), 6000);
+    card.addEventListener('pointerdown', () => {
+        clearTimeout(autoCloseTimer);
+        autoCloseTimer = setTimeout(() => card.remove(), 6000);
+    });
+}
