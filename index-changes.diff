+/* ════════════════════════════════════════════════════════════════════
+   4. Tiki Ritme — Simon Says met Tiki-maskers
+   ════════════════════════════════════════════════════════════════════
+   Per speler: sequence van Tiki-maskers herhalen. Elke ronde +1 lengte.
+   Fout = einde voor deze speler, level = score.
+   Hoogste level wint.
+   ════════════════════════════════════════════════════════════════════ */
+function playTikiRitme({ players = G.players, drinks = 3 } = {}) {
+    return new Promise(resolve => {
+        const ui = document.getElementById('game-ui');
+        const back = el('div', { className: 'tiki-back' });
+        const head = el('div', { className: 'tiki-head' });
+        head.append(el('h2', {}, '🗿 Tiki Ritme'));
+        const status = el('div', { className: 'tiki-status' });
+        const pChip = el('div', { className: 'tiki-chip' });
+        pChip.append(el('div', { className: 'lbl' }, 'Speler'));
+        const pVal = el('div', { className: 'val' }, '–');
+        pChip.append(pVal);
+        const lChip = el('div', { className: 'tiki-chip' });
+        lChip.append(el('div', { className: 'lbl' }, 'Level'));
+        const lVal = el('div', { className: 'val' }, '1');
+        lChip.append(lVal);
+        status.append(pChip, lChip);
+        const tip = el('div', { className: 'tiki-tip' }, "Onthoud de volgorde en tik 'm terug");
+        // 4 maskers
+        const stage = el('div', { className: 'tiki-stage' });
+        const COLORS = ['#a87a4a', '#c8501a', '#3a8a4a', '#a85aa8'];   // 4 base colors
+        const SYMBOLS = ['🗿', '🗿', '🗿', '🗿'];
+        const masks = [];
+        for (let i = 0; i < 4; i++) {
+            const m = el('div', { className: 'tiki-mask',
+                'data-i': String(i),
+                style: { '--litcol': COLORS[i] } }, SYMBOLS[i]);
+            masks.push(m);
+            stage.append(m);
+        }
+        back.append(head, status, tip, stage);
+        ui.append(back);
+
+        // ── STATE ──
+        const sequences = [];          // {player, sequence: number[], level}
+        let curIdx = 0;
+        let curSeq = [];               // huidige sequence voor deze speler
+        let level = 0;                 // hoeveel je succesvol terug hebt gespeeld
+        let inputIdx = 0;              // waar staat de speler in zijn input
+        let phase = 'intro';           // intro | showing | listening | failed | between | done
+        let locked = false;            // taps geblokkeerd tijdens showing
+
+        function setPlayer(i) {
+            curIdx = i;
+            const p = players[curIdx];
+            pVal.textContent = p.name;
+            pVal.style.color = p.color.css;
+            pChip.style.setProperty('--pcol', p.color.css);
+            lChip.style.setProperty('--pcol', p.color.css);
+            curSeq = [];
+            level = 0;
+            lVal.textContent = '1';
+        }
+        function flashMask(i, dur = 500) {
+            const m = masks[i];
+            m.classList.add('lit');
+            // Eenvoudig "sound" effect via WebAudio (sine-tone per index)
+            playTone(220 + i * 80, dur);
+            return new Promise(r => setTimeout(() => {
+                m.classList.remove('lit');
+                setTimeout(r, 120);
+            }, dur));
+        }
+        let audioCtx = null;
+        function playTone(freq, dur) {
+            try {
+                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
+                const o = audioCtx.createOscillator();
+                const g = audioCtx.createGain();
+                o.type = 'triangle';
+                o.frequency.value = freq;
+                g.gain.setValueAtTime(0, audioCtx.currentTime);
+                g.gain.linearRampToValueAtTime(0.18, audioCtx.currentTime + 0.03);
+                g.gain.linearRampToValueAtTime(0, audioCtx.currentTime + dur/1000);
+                o.connect(g); g.connect(audioCtx.destination);
+                o.start(); o.stop(audioCtx.currentTime + dur/1000 + 0.05);
+            } catch (e) {}
+        }
+        async function showSequence() {
+            phase = 'showing';
+            locked = true;
+            stage.classList.add('tiki-locked');
+            tip.textContent = 'Kijk goed...';
+            await new Promise(r => setTimeout(r, 600));
+            for (const idx of curSeq) {
+                await flashMask(idx, 460);
+            }
+            phase = 'listening';
+            locked = false;
+            stage.classList.remove('tiki-locked');
+            inputIdx = 0;
+            tip.textContent = 'Jouw beurt — tik in dezelfde volgorde';
+        }
+        function nextLevel() {
+            // Voeg willekeurige tik toe
+            curSeq.push(Math.floor(Math.random() * 4));
+            lVal.textContent = String(curSeq.length);
+            showSequence();
+        }
+        function onTap(i) {
+            if (locked || phase !== 'listening') return;
+            // Flash de getikte mask (zonder geluid om timing te houden)
+            const m = masks[i];
+            m.classList.add('lit');
+            playTone(220 + i * 80, 220);
+            setTimeout(() => m.classList.remove('lit'), 220);
+            const expected = curSeq[inputIdx];
+            if (i !== expected) {
+                fail();
+                return;
+            }
+            inputIdx++;
+            if (inputIdx >= curSeq.length) {
+                // Level klaar
+                level = curSeq.length;
+                tip.textContent = 'Goed!';
+                setTimeout(nextLevel, 700);
+            }
+        }
+        function fail() {
+            phase = 'failed';
+            locked = true;
+            stage.classList.add('tiki-locked');
+            playTone(120, 800);
+            tip.textContent = '❌ Fout!';
+            sequences.push({ player: players[curIdx], level });
+            const p = players[curIdx];
+            const banner = el('div', { className: 'tiki-banner',
+                style: { '--pcol': p.color.css } });
+            banner.append(
+                el('h2', {}, `${p.name}`),
+                el('div', { className: 'big' }, `Level ${level}`),
+                el('p', {}, level === 0 ? 'Niet eens 1 onthouden... 😅' :
+                            `${level} tikken in volgorde geweldig!`),
+            );
+            stage.append(banner);
+            setTimeout(() => {
+                banner.remove();
+                if (curIdx < players.length - 1) {
+                    setPlayer(curIdx + 1);
+                    setTimeout(nextLevel, 400);
+                } else {
+                    showFinal();
+                }
+            }, 2200);
+        }
+        function showFinal() {
+            phase = 'done';
+            const sorted = [...sequences].sort((a, b) => b.level - a.level);
+            const topL = sorted[0].level;
+            const losers = sorted.filter(s => s.level < topL);
+            const banner = el('div', { className: 'tiki-banner',
+                style: { '--pcol': sorted[0].player.color.css } });
+            const ranking = el('div', { style: {
+                margin: '12px 0', display: 'flex', flexDirection: 'column', gap: '6px' } });
+            sorted.forEach((s, i) => {
+                ranking.append(el('div', { style: {
+                    display: 'flex', justifyContent: 'space-between', gap: '12px',
+                    padding: '6px 12px', borderRadius: '8px',
+                    background: 'rgba(255,255,255,0.08)',
+                    border: '1px solid ' + s.player.color.css,
+                    opacity: s.level === topL ? '1' : '0.65' } },
+                    el('span', {}, `${i+1}. ${s.player.name}`),
+                    el('span', { style: { color: s.player.color.css, fontWeight: '900' } },
+                        `lvl ${s.level}`),
+                ));
+            });
+            banner.append(
+                el('h2', {}, '🏆 Eindstand'),
+                ranking,
+                el('p', {}, losers.length === 0 ? 'Gelijkspel — proost!' :
+                    `${losers.map(l => l.player.name).join(', ')} drinkt elk ${drinks} 🍻`),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => finish(sorted) } }, 'Klaar'),
+            );
+            stage.append(banner);
+            setTimeout(() => finish(sorted), 9000);
+        }
+        function finish(sorted) {
+            if (phase === 'closed') return;
+            phase = 'closed';
+            back.style.transition = 'opacity 0.3s ease';
+            back.style.opacity = '0';
+            setTimeout(() => { back.remove(); resolve(sorted || null); }, 300);
+        }
+
+        masks.forEach((m, i) => {
+            m.addEventListener('touchstart', e => { e.preventDefault(); onTap(i); },
+                { passive: false });
+            m.addEventListener('mousedown', () => onTap(i));
+        });
+
+        // Start eerste speler
+        setPlayer(0);
+        setTimeout(nextLevel, 600);
     });
 }
 
