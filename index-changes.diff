+            } else if (phase === 'rolling' && ball) {
+                // Volg de bal met soepele lerp. Camera Z blijft vast op
+                // BOWL.cz zodat we niet zigzaggen als de bal curveert.
+                const targetPos = camPosForBall(ball.position.x);
+                const targetTgt = camTgtForBall(ball.position.x);
+                const k = Math.min(1, dt * 3.0);
+                camera.position.lerp(targetPos, k);
+                controls.target.lerp(targetTgt, k);
+                camera.lookAt(controls.target);
+            } else if (phase === 'result_wait' || phase === 'result') {
+                // Houd camera ongeveer waar 'ie nu is — lerp licht naar
+                // pin-cam zodat impact-shot zichtbaar wordt
