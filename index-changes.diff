+                if (curIdx < players.length - 1) startRun(curIdx + 1);
+                else showFinal();
+            }, 2200);
+        }
+        function showFinal() {
+            phase = 'done';
+            const sorted = [...scores].sort((a, b) => b.score - a.score);
+            const topS = sorted[0].score;
+            const winners = sorted.filter(s => s.score === topS);
+            const losers = sorted.filter(s => s.score < topS);
+            const winName = winners.map(w => w.player.name).join(' & ');
+            const banner = el('div', { className: 'krab-banner',
+                style: { '--pcol': winners[0].player.color.css } });
+            const ranking = el('div', { style: {
+                margin: '12px 0', display: 'flex', flexDirection: 'column', gap: '6px' } });
+            sorted.forEach((s, i) => {
+                ranking.append(el('div', { style: {
+                    display: 'flex', justifyContent: 'space-between', gap: '12px',
+                    padding: '6px 12px', borderRadius: '8px',
+                    background: 'rgba(255,255,255,0.08)',
+                    border: '1px solid ' + s.player.color.css,
+                    opacity: s.score === topS ? '1' : '0.65' } },
+                    el('span', {}, `${i+1}. ${s.player.name}`),
+                    el('span', { style: { color: s.player.color.css, fontWeight: '900' } },
+                        String(s.score)),
+                ));
+            });
+            banner.append(
+                el('h2', {}, '🏆 Eindstand'),
+                ranking,
+                el('p', {}, losers.length === 0 ? 'Gelijkspel — proost!' :
+                    `${losers.map(l => l.player.name).join(', ')} drinkt elk ${drinks} 🍻`),
+                el('button', { className: 'btn-pill gold', type: 'button',
+                    style: { marginTop: '10px' },
+                    on: { click: () => finish(sorted) } }, 'Klaar'),
+            );
+            stage.append(banner);
+            setTimeout(() => finish(sorted), 8000);
+        }
+        function finish(sorted) {
+            if (phase === 'closed') return;
+            phase = 'closed';
+            cancelAnimationFrame(rafId);
+            back.style.transition = 'opacity 0.3s ease';
+            back.style.opacity = '0';
+            setTimeout(() => { back.remove(); resolve(sorted || null); }, 300);
+        }
+
+        let rafId = 0, lastT = 0;
+        function tick(t) {
+            const dt = lastT ? (t - lastT) / 1000 : 0;
+            lastT = t;
+            if (phase === 'playing') {
+                const elapsed = performance.now() - phaseStart;
+                const remaining = Math.max(0, ROUND_MS - elapsed);
+                tVal.textContent = Math.ceil(remaining / 1000).toString();
+                // Spawn ritme versnelt: 0.55s → 0.30s
+                const t01 = elapsed / ROUND_MS;
+                crabSpawnInterval = 0.55 - t01 * 0.25;
+                crabSpawnTimer += dt;
+                if (crabSpawnTimer >= crabSpawnInterval) {
+                    crabSpawnTimer -= crabSpawnInterval;
+                    spawnCrab();
+                }
+                // Expire crabs
+                const now = performance.now();
+                for (let i = activeCrabs.length - 1; i >= 0; i--) {
+                    if (!activeCrabs[i].hit && now >= activeCrabs[i].expireAt) {
+                        expireCrab(activeCrabs[i]);
+                    }
+                }
+                if (elapsed >= ROUND_MS) endRun();
+            }
+            rafId = requestAnimationFrame(tick);
+        }
+        // Wacht tot stage layout heeft, dan starten
+        setTimeout(() => {
+            layoutHoles();
+            window.addEventListener('resize', () => layoutHoles());
+            startRun(0);
+            rafId = requestAnimationFrame(tick);
+        }, 50);
+    });
+}
