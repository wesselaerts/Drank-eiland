+// ── Bell sparkle (zeldzaam, hoog) — wind-chime ──
+function bgPlayBellSparkle(time, freq, velocity = 1.0) {
+    const ctx = bgMusic.ctx;
+    const dest = bgMusic.master;
+    if (!ctx || !dest) return;
+    const bell = ctx.createOscillator();
+    bell.type = 'sine';
+    bell.frequency.value = freq;
+    const bg2 = ctx.createGain();
+    bg2.gain.setValueAtTime(0, time);
+    bg2.gain.linearRampToValueAtTime(0.016 * velocity, time + 0.02);
+    bg2.gain.exponentialRampToValueAtTime(0.001, time + 2.5);
+    bell.connect(bg2);
+    bg2.connect(dest);
+    bell.start(time);
+    bell.stop(time + 2.7);
