+            toast._t = setTimeout(() => toast.style.display = 'none', ms);
+        }
+
+        // ════════════════════════════════════════════════════════
+        //  G. PIN-RESET + FALL
+        // ════════════════════════════════════════════════════════
+        function resetPins() {
+            for (const pin of bowlingPins) {
+                pin.position.copy(pin.userData.basePos);
+                pin.quaternion.copy(pin.userData.baseQuat);
+                pin.userData.fallen = false;
+                pin.userData.fallProgress = 0;
+                pin.userData.fallAxis = null;
+                pin.userData.fallTime = 0;
+            }
+            fallenPinsThisRound.clear();
+        }
+        function knockDownPin(pin, fromPos, time) {
+            if (pin.userData.fallen) return;
+            pin.userData.fallen = true;
+            pin.userData.fallTime = time;
+            // Richting weg van de impact (in xz-vlak)
+            const dx = pin.position.x - fromPos.x;
+            const dz = pin.position.z - fromPos.z;
+            const len = Math.hypot(dx, dz) || 1;
+            const fx = dx / len, fz = dz / len;
+            // Rotatie-as loodrecht op valrichting (in xz-vlak)
+            pin.userData.fallAxis = new THREE.Vector3(fz, 0, -fx).normalize();
+            pin.userData.fallDir = { x: fx, z: fz };
+            fallenPinsThisRound.add(pin);
+            // Directional cascade — alleen pinnen in de val-richting
+            // krijgen een hoge kans om mee te vallen. Pinnen erachter
+            // hebben een lage kans. Dit voorkomt domino-everything.
+            const depth = pin.userData.cascadeDepth || 0;
+            setTimeout(() => {
+                cascadePin(pin, fx, fz, depth + 1);
+            }, depth === 0 ? 90 : 130);
+        }
+        function cascadePin(srcPin, prevDx, prevDz, depth) {
+            if (depth > 3) return;
+            for (const other of bowlingPins) {
+                if (other === srcPin || other.userData.fallen) continue;
+                const dx = other.position.x - srcPin.position.x;
+                const dz = other.position.z - srcPin.position.z;
+                const d = Math.hypot(dx, dz);
+                if (d >= CHAIN_R) continue;        // alleen directe buren
+                const nx = dx / d, nz = dz / d;
+                // Dot-product: 1 = recht voor val-richting,
+                // -1 = achter de gevallen pin
+                const dot = nx * prevDx + nz * prevDz;
+                let chance;
+                if (dot > 0.55) chance = 0.92;     // recht in val-richting
+                else if (dot > 0.15) chance = 0.55;// diagonaal voor
+                else if (dot > -0.20) chance = 0.18;// zijwaarts
+                else chance = 0.03;                 // achter (zelden)
+                // Depth-penalty zodat het niet alle pinnen wegslaat
+                if (depth >= 2) chance *= 0.45;
+                if (depth >= 3) chance *= 0.30;
+                if (Math.random() < chance) {
+                    other.userData.cascadeDepth = depth;
+                    knockDownPin(other, srcPin.position.clone(),
+                        performance.now() / 1000);
+                }
+            }
+        }
+
+        // ════════════════════════════════════════════════════════
+        //  H. RUN-LIFECYCLE
+        // ════════════════════════════════════════════════════════
+        function startRunFor(playerIdx) {
