+/* ════════════════════════════════════════════════════════════════════
+   1. De Hete Lavasteen — Hot Potato
+   ════════════════════════════════════════════════════════════════════
+   State machine:
+     START       — eerste speler vasthoudt, knop "Geef door"
+     PASSING     — taps wisselen speler; verborgen timer telt door
+     EXPLODE     — timer eindigt, huidige speler verliest
+                   visueel: rook + boom + result-card → resolve()
+   ════════════════════════════════════════════════════════════════════ */
+function playHeteLavasteen({ players = G.players, drinks = 4 } = {}) {
+    return new Promise(resolve => {
+        const ui = document.getElementById('game-ui');
+        const back = el('div', { className: 'lava-back' });
+        const head = el('div', { className: 'lava-head' });
+        head.append(el('h2', {}, '🌋 De Hete Lavasteen'));
+        // Speler-badge
+        const turn = el('div', { className: 'lava-turn' });
+        const turnDot = el('span', { className: 'dot' });
+        const turnName = el('span', { className: 'name' });
+        turn.append(el('span', { style: { fontSize: '13px', opacity: '0.7' } }, 'Vasthoudt:'),
+                    turnDot, turnName);
+        head.append(turn);
+        // Stage met de steen
+        const stage = el('div', { className: 'lava-stage' });
+        const rock = el('div', { className: 'lava-rock' });
+        rock.style.setProperty('--heat', '0');
+        stage.append(rock);
+        // Tap-knop (zit absoluut in de stage)
+        const tap = el('button', { className: 'lava-tap', type: 'button' }, 'Geef door 👆');
+        stage.append(tap);
+        // Subtle hint onderaan
+        const tip = el('div', { style: {
+            textAlign: 'center', fontSize: '13px', opacity: '0.65', padding: '6px 14px' } },
+            "Tik om de telefoon door te geven. Wie 'm vasthoudt als de steen ontploft, drinkt.");
+        back.append(head, stage, tip);
+        ui.append(back);
+
+        // ── STATE ──
+        let curIdx = 0;
+        // Verborgen timer 8-16 seconden (escaleert visueel naar het einde)
+        const TOTAL_MS = 8000 + Math.random() * 8000;
+        const startedAt = performance.now();
+        let phase = 'passing';     // passing | exploded | done
+        let rafId = 0;
+
+        function setPlayer(i) {
+            curIdx = i;
+            const p = players[curIdx];
+            turnDot.style.background = p.color.css;
+            turnDot.style.boxShadow = '0 0 8px ' + p.color.css;
+            turnName.style.color = p.color.css;
+            turnName.textContent = p.name;
+            turn.style.setProperty('--pcol', p.color.css);
+        }
+        setPlayer(0);
+
+        function tick() {
+            if (phase !== 'passing') return;
+            const elapsed = performance.now() - startedAt;
+            const ratio = Math.min(1, elapsed / TOTAL_MS);
+            rock.style.setProperty('--heat', ratio.toFixed(3));
+            if (elapsed >= TOTAL_MS) {
+                explode();
+            } else {
+                rafId = requestAnimationFrame(tick);
+            }
+        }
+        function passToNext() {
+            if (phase !== 'passing') return;
+            setPlayer((curIdx + 1) % players.length);
+            // Tactiele tap feedback — kleine puls
+            tap.style.transform = 'translateX(-50%) scale(0.92)';
+            setTimeout(() => { tap.style.transform = ''; }, 100);
+        }
+        function explode() {
+            if (phase !== 'passing') return;
+            phase = 'exploded';
+            const loser = players[curIdx];
+            // Visuele klap
+            const boom = el('div', { className: 'lava-explosion' });
+            stage.append(boom);
+            rock.style.opacity = '0';
+            rock.style.transform = 'scale(0)';
+            rock.style.transition = 'all 0.3s ease-out';
+            tap.style.display = 'none';
+            // Resultaat-card
+            setTimeout(() => {
+                boom.remove();
+                const result = el('div', { className: 'lava-result',
+                    style: { '--pcol': loser.color.css } });
+                result.append(
+                    el('h2', {}, '💥 BOEM!'),
+                    el('p', {}, `${loser.name} houdt 'm vast`),
+                    el('p', { style: { fontSize: '18px', marginTop: '8px', fontWeight: '900' } },
+                        `${drinks} slokken 🍻`),
+                );
+                stage.append(result);
+                setTimeout(() => finish(loser), 2400);
+            }, 600);
+        }
+        function finish(loser) {
+            if (phase === 'done') return;
+            phase = 'done';
+            cancelAnimationFrame(rafId);
             back.style.transition = 'opacity 0.3s ease';
             back.style.opacity = '0';
             setTimeout(() => { back.remove(); resolve(loser); }, 300);
         }
+        tap.addEventListener('click', passToNext);
+        tap.addEventListener('touchstart', e => { e.preventDefault(); passToNext(); },
+            { passive: false });
+        rafId = requestAnimationFrame(tick);
+    });
+}
