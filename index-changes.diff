+        }
+
+        // ════════════════════════════════════════════════════════
+        //  I. INPUT — sweep met path-tracking (zoals oude bowling)
+        // ════════════════════════════════════════════════════════
+        // Een drag genereert een PATH van samples. Daaruit halen we:
+        //  - power (uit swipe-speed in de laatste 200ms)
+        //  - aimAngle (uit horizontale verplaatsing)
+        //  - spin (uit verschil in horizontale beweging eerste vs
+        //          tweede helft van het pad = curvature)
+        // Tijdens het slepen tonen we live in 3D een gekromde tube
+        // (aim-arrow) waar de bal naartoe zal gaan.
+        function buildAimArrow(power, aimAngle, spin, active) {
+            // Clean up oude meshes
+            while (aimArrow.children.length) {
+                const c = aimArrow.children[0];
+                aimArrow.remove(c);
+                if (c.geometry) c.geometry.dispose();
+                if (c.material) c.material.dispose();
+            }
+            if (!ball) return;
+            const startX = ball.position.x;
+            const startZ = ball.position.z;
+            const len = 4 + power * 12;
+            // Bouw curve-punten — bal beweegt in -X richting, met
+            // aim-offset op Z en quadratic spin-curve op Z.
+            const points = [];
+            const segments = 28;
+            for (let i = 0; i <= segments; i++) {
+                const t = i / segments;
+                const x = startX - t * len;
+                // aim: lineair offset; spin: kwadratische curve
+                const z = startZ
+                    - Math.sin(aimAngle) * t * len
+                    - spin * 0.55 * t * t * len;
+                points.push(new THREE.Vector3(x, ALLEY_TOP_Y + 0.02, z));
+            }
+            // Kleur shift met power: groen → geel → rood
+            const r = active ? Math.min(255, 80 + power * 255) : 255;
+            const g = active ? Math.min(255, 220 - power * 100) : 200;
+            const b = active ? 30 : 80;
+            const color = (r << 16) | (g << 8) | b;
+            const opacity = active ? 0.85 : 0.30;
+            const curve = new THREE.CatmullRomCurve3(points);
+            // Buitenste glow
+            const glow = new THREE.Mesh(
+                new THREE.TubeGeometry(curve, segments, 0.055, 8, false),
+                new THREE.MeshBasicMaterial({
+                    color, transparent: true, opacity: opacity * 0.4,
+                    depthTest: false, depthWrite: false }));
+            glow.renderOrder = 4;
+            aimArrow.add(glow);
+            // Binnenste tube
+            const tube = new THREE.Mesh(
+                new THREE.TubeGeometry(curve, segments, 0.028, 6, false),
+                new THREE.MeshBasicMaterial({
+                    color, transparent: true, opacity,
+                    depthTest: false, depthWrite: false }));
+            tube.renderOrder = 5;
+            aimArrow.add(tube);
+            // Cone aan tip
+            const tipPos = points[points.length - 1];
+            const tipPrev = points[points.length - 4];
+            const tipDir = new THREE.Vector3().subVectors(tipPos, tipPrev).normalize();
+            const cone = new THREE.Mesh(
+                new THREE.ConeGeometry(0.11, 0.26, 10),
+                new THREE.MeshBasicMaterial({
+                    color: active ? 0xff5722 : 0xffaa00,
+                    transparent: true, opacity,
+                    depthTest: false, depthWrite: false }));
+            cone.position.copy(tipPos);
+            cone.position.y = ALLEY_TOP_Y + 0.10;
+            cone.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tipDir);
+            cone.renderOrder = 6;
+            aimArrow.add(cone);
+        }
+        function computeDragParams() {
+            const dy = drag.sy - drag.cy;            // omhoog positief
+            const dx = drag.cx - drag.sx;            // rechts positief
+            // Power: vertical drag distance (live), 0-1
+            const power = Math.min(1, Math.max(0, dy / (window.innerHeight * 0.30)));
+            // AimAngle: horizontal drag (small, ~ -0.14..0.14 rad)
+            const aimAngle = Math.max(-0.14, Math.min(0.14,
+                (dx / window.innerWidth) * 0.40));
+            // Spin: path curvature — verschil tussen eerste en tweede
+            // helft van horizontale beweging in samples
+            let spin = 0;
+            if (drag.samples.length >= 4) {
+                const mid = Math.floor(drag.samples.length / 2);
+                const h1 = drag.samples[mid].x - drag.samples[0].x;
+                const h2 = drag.samples[drag.samples.length - 1].x
+                    - drag.samples[mid].x;
+                const diff = h2 - h1;
+                spin = Math.max(-0.35, Math.min(0.35,
+                    diff / (window.innerWidth * 0.35)));
+            }
+            return { power, aimAngle, spin, dy, dx };
+        }
+        function computeReleaseParams() {
+            // Bereken throw-params met swipe-speed (last ~200ms)
+            const params = computeDragParams();
+            let swipeSpeed = 0;
+            if (drag.samples.length >= 2) {
+                const cutoff = drag.lastT - 200;
+                let s0 = drag.samples[0];
+                for (const s of drag.samples) {
+                    if (s.t >= cutoff) { s0 = s; break; }
+                }
+                const sdy = s0.y - drag.cy;
+                const sdt = Math.max(0.05, (drag.lastT - s0.t) / 1000);
+                swipeSpeed = sdy / sdt;
+            }
+            // Power op release = combinatie van afgelegde afstand
+            // en swipe-snelheid (zoals oude bowling)
+            const releasePower = Math.min(1,
+                Math.max(0.40, swipeSpeed / 1800));
+            return { ...params, power: releasePower, swipeSpeed };
+        }
+        function updatePowerMeter(power) {
+            powerBar.style.transform = `scaleX(${power.toFixed(3)})`;
+            powerLbl.textContent = power < 0.35 ? 'ZACHT' :
+                                    power < 0.70 ? 'GEMIDDELD' : 'MAX POWER';
+        }
+        function onDragStart(cx, cy, id) {
+            if (phase !== 'ready' && phase !== 'aiming') return;
