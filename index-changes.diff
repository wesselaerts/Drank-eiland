+// ── MARIMBA (wooden bars, tropical accent) ──
+//   Vrije-vrije balk-trillingsmodes: f_n ∝ (n+0.5)² door buigstijfheid.
+//   In de praktijk worden marimba's getuned op 1:4:10 verhoudingen
+//   (klassieke "marimba-tuning"). Kort decay door demping van hout.
+//   Triangle-wave geeft warmere klank dan pure sine.
+function bgPlayMarimba(time, f1, velocity = 1.0) {
+    const ctx = bgMusic.ctx;
+    const dest = bgMusic.master;
+    if (!ctx || !dest) return;
+
+    const partials = [
+        { ratio:  1.00, amp: 1.00, decay: 1.4 },   // fundamental — kort!
+        { ratio:  4.00, amp: 0.35, decay: 0.7 },   // bar mode 2 (stiff)
+        { ratio: 10.00, amp: 0.12, decay: 0.3 },   // bar mode 3 (knock)
+    ];
+    const baseAmp = 0.032 * velocity;
+
+    for (const p of partials) {
+        const osc = ctx.createOscillator();
+        // Eerste partial triangle (warm), hogere modes sine (helder)
+        osc.type = p.ratio === 1.00 ? 'triangle' : 'sine';
+        osc.frequency.value = f1 * p.ratio;
+        osc.detune.value = (Math.random() - 0.5) * 6;
+
+        const g = ctx.createGain();
+        g.gain.setValueAtTime(0, time);
+        // Heel sharp attack (3ms) — mallet-on-wood
+        g.gain.linearRampToValueAtTime(baseAmp * p.amp, time + 0.003);
+        g.gain.exponentialRampToValueAtTime(0.0001, time + p.decay);
+
+        osc.connect(g);
+        g.connect(dest);
+        osc.start(time);
+        osc.stop(time + p.decay + 0.1);
+    }
+}
