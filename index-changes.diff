+            const maxSpeed = 14;
+            const speed = minSpeed + power01 * (maxSpeed - minSpeed);
+            // Bal vliegt langs -X (richting pinnen). aimAngle bepaalt
+            // hoek in xz-vlak. spin geeft laterale acceleratie in Z.
