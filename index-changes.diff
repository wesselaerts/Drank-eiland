+            drag.sx = drag.cx = cx;
+            drag.sy = drag.cy = cy;
+            drag.startT = drag.lastT = performance.now();
+            drag.samples = [{ x: cx, y: cy, t: drag.startT }];
+            phase = 'aiming';
+            setBanner('', '');
+            setTip('Veeg omhoog om te werpen — bocht voor spin');
