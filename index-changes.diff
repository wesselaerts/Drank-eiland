+// ════════════════════════════════════════════════════════════════
+//  ROUND-END ALL-PLAYER MINIGAME TRIGGER
+// ════════════════════════════════════════════════════════════════
+//  Alle-spelers minigames (volcano, tappy, bowling, lavasteen, etc.)
+//  worden niet meer getriggerd door een tile op het bord. In plaats
+//  daarvan vuren ze automatisch aan het einde van een ronde-blok,
+//  zodat het tempo onafhankelijk van het aantal spelers vergelijk-
+//  baar blijft: ongeveer 8 individuele beurten per groeps-minigame.
+//
+//    Spelers   Rondes tussen minigames   Beurten tussen
+//      8                1                       8
+//      4                2                       8
+//      2                4                       8
+//      3                3                       9
+//      5/6/7            2                       10-14
+//
+//  Anti-repeat shuffled pool: alle 7 minigames worden in willekeur-
+//  ige volgorde afgewerkt voor er een herhaling komt.
+// ════════════════════════════════════════════════════════════════
+async function maybeRunAllPlayerRoundGame() {
+    if (G.players.length < 2) return;
+    // Alleen triggeren wanneer de ronde NET is gewikkeld
+    // (advanceTurn heeft G.turnIdx naar 0 gerold).
+    if (G.turnIdx !== 0) return;
+    if (G._roundsSinceAllPlayer === undefined) G._roundsSinceAllPlayer = 0;
+    G._roundsSinceAllPlayer++;
+    const threshold = Math.max(1, Math.ceil(8 / G.players.length));
+    if (G._roundsSinceAllPlayer < threshold) return;
+    G._roundsSinceAllPlayer = 0;
+
+    // Anti-repeat shuffled pool — werkt alle minigames af voor
+    // herhaling. Fisher-Yates shuffle wanneer leeg.
+    if (!G._allPlayerPool || G._allPlayerPool.length === 0) {
+        const pool = [...ALL_PLAYER_GAMES];
+        for (let i = pool.length - 1; i > 0; i--) {
+            const j = Math.floor(Math.random() * (i + 1));
+            [pool[i], pool[j]] = [pool[j], pool[i]];
+        }
+        G._allPlayerPool = pool;
+    }
+    const id = G._allPlayerPool.shift();
+
+    G.phase = 'event';
+    refreshHUD();
+    await showStamp({
+        emoji: '🎉', big: 'GROEPSMINIGAME!',
+        sub: 'Iedereen doet mee — einde ronde-blok!',
+        palette: 'gold', auto: true, duration: 1600,
+    });
+    // De dispatcher heeft een 'player' param nodig maar voor all-player
+    // games doet 't er niet toe wie — gebruik de eerste in de lijst.
+    await runMinigameOnTile(id, G.players[0]);
+    G.phase = 'idle';
+}
