+// ── Chord pad: 3 sine voices, smooth crossfade ──
+function bgPlayChordPad(time, chord, duration) {
+    const ctx = bgMusic.ctx;
+    const dest = bgMusic.master;
+    if (!ctx || !dest) return;
+    const attack = 1.5;
+    const release = 1.5;
+    const sustain = Math.max(0.5, duration - attack - release * 0.5);
+
+    for (const freq of chord.notes) {
+        const osc = ctx.createOscillator();
+        osc.type = 'sine';
+        osc.frequency.value = freq;
+        const vib = ctx.createOscillator();
+        vib.frequency.value = 4.0;
+        const vibG = ctx.createGain();
+        vibG.gain.value = freq * 0.0015;
+        vib.connect(vibG);
+        vibG.connect(osc.frequency);
+
+        const g = ctx.createGain();
+        const peakVol = 0.036;
+        g.gain.setValueAtTime(0, time);
+        g.gain.linearRampToValueAtTime(peakVol, time + attack);
+        g.gain.linearRampToValueAtTime(peakVol * 0.85, time + attack + sustain);
+        g.gain.linearRampToValueAtTime(0, time + attack + sustain + release);
+        osc.connect(g); g.connect(dest);
+        const tEnd = time + attack + sustain + release + 0.1;
+        osc.start(time);  vib.start(time);
+        osc.stop(tEnd);   vib.stop(tEnd);
+    }
