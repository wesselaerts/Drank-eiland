+                list.append(row);
+            });
+            ko.append(list);
+            const drinkMsg = losers.length === 0 ? 'Iedereen gelijk — proost!' :
+                `${losers.map(l => l.player.name).join(', ')} drinkt elk ${drinks} 🍻`;
+            ko.append(el('p', {}, drinkMsg));
