+// ════════════════════════════════════════════════════════════════
+//  JAIL / BANANA BRIG PAWN MANAGEMENT
+// ════════════════════════════════════════════════════════════════
+//  Banana Brig satelliet staat op wereld (4, 0, -19) met grass-top
+//  y=2.4. De stenen plateau zit op y=2.65, de bamboe-kooi op y=2.85
+//  met radius 1.55 en hoogte 2.4 — binnenruimte ruim genoeg voor
+//  meerdere pawns.
+//
+//  Een vastzittende speler's token gaat NAAR de jail-positie (binnen
+//  de kooi), terwijl player.tileIdx blijft staan op de skull-tegel
+//  waar 'ie verbannen werd. Bij ontsnappen vliegt de pawn terug naar
+//  die tegel om vervolgens normaal te bewegen.
+//
+//  Bij meerdere gevangen spelers worden ze in een klein cirkeltje
+//  binnen de kooi gerangschikt.
+// ════════════════════════════════════════════════════════════════
+const JAIL_WORLD_POS = new THREE.Vector3(4, 3.0, -19);
+
+function jailPositionFor(player) {
+    const jailed = G.players.filter(p => p.inPrison);
+    const idx = jailed.indexOf(player);
+    if (idx === -1 || jailed.length <= 1) return JAIL_WORLD_POS.clone();
+    const angle = (idx / jailed.length) * Math.PI * 2;
+    const r = 0.5;
+    return new THREE.Vector3(
+        JAIL_WORLD_POS.x + Math.cos(angle) * r,
+        JAIL_WORLD_POS.y,
+        JAIL_WORLD_POS.z + Math.sin(angle) * r,
+    );
+}
+
+function layoutJailedTokens() {
+    const jailed = G.players.filter(p => p.inPrison);
+    jailed.forEach((p, idx) => {
+        const angle = jailed.length <= 1 ? 0 : (idx / jailed.length) * Math.PI * 2;
+        const r = jailed.length <= 1 ? 0 : 0.5;
+        p.token.position.set(
+            JAIL_WORLD_POS.x + Math.cos(angle) * r,
+            JAIL_WORLD_POS.y,
+            JAIL_WORLD_POS.z + Math.sin(angle) * r,
+        );
+    });
+}
+
+function animateTokenToJail(player, durMs = 800, arcH = 2.0) {
+    return new Promise(resolve => {
+        const startPos = player.token.position.clone();
+        const endPos = jailPositionFor(player);
+        const startTime = performance.now();
+        const step = (now) => {
+            const k = Math.min(1, (now - startTime) / durMs);
+            const ease = 1 - Math.pow(1 - k, 2.5);
+            player.token.position.lerpVectors(startPos, endPos, ease);
+            player.token.position.y += Math.sin(k * Math.PI) * arcH;
+            if (k < 1) requestAnimationFrame(step);
+            else {
+                player.token.position.copy(endPos);
+                layoutJailedTokens();
+                resolve();
+            }
+        };
+        requestAnimationFrame(step);
+    });
+}
+
+function animateTokenFromJail(player, durMs = 800, arcH = 2.0) {
+    return new Promise(resolve => {
+        const startPos = player.token.position.clone();
+        const endPos = tileWorldPos[player.tileIdx].clone();
+        endPos.y += 0.25;
+        const startTime = performance.now();
+        const step = (now) => {
+            const k = Math.min(1, (now - startTime) / durMs);
+            const ease = 1 - Math.pow(1 - k, 2.5);
+            player.token.position.lerpVectors(startPos, endPos, ease);
+            player.token.position.y += Math.sin(k * Math.PI) * arcH;
+            if (k < 1) requestAnimationFrame(step);
+            else {
+                player.token.position.copy(endPos);
+                layoutTokensOnTile(player.tileIdx);
+                layoutJailedTokens();
+                resolve();
+            }
+        };
+        requestAnimationFrame(step);
+    });
+}
+
+function lerpCameraTo(toPos, toTgt, durMs = 700) {
+    return new Promise(resolve => {
+        const fromPos = camera.position.clone();
+        const fromTgt = controls.target.clone();
+        const t0 = performance.now();
+        const step = (now) => {
+            const k = Math.min(1, (now - t0) / durMs);
+            const e = k < 0.5 ? 4*k*k*k : 1 - Math.pow(-2*k+2, 3) / 2;
+            camera.position.lerpVectors(fromPos, toPos, e);
+            controls.target.lerpVectors(fromTgt, toTgt, e);
+            if (k < 1) requestAnimationFrame(step);
+            else resolve();
+        };
+        requestAnimationFrame(step);
+    });
+}
+
+// Dramatische zoom op Banana Brig — voor POV op de gevangen speler
+async function zoomCameraToJail(durMs = 700) {
+    const camTo = new THREE.Vector3(
+        JAIL_WORLD_POS.x + 4,
+        JAIL_WORLD_POS.y + 3,
+        JAIL_WORLD_POS.z + 5,
+    );
+    const tgtTo = new THREE.Vector3(
+        JAIL_WORLD_POS.x,
+        JAIL_WORLD_POS.y + 0.5,
+        JAIL_WORLD_POS.z,
+    );
+    await lerpCameraTo(camTo, tgtTo, durMs);
+}
