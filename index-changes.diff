+            phaseT = 0;
+            rollStartTime = performance.now() / 1000;
+            setTip('');
+        }
+        tbHit.addEventListener('touchstart', e => {
+            e.preventDefault();
+            const t = e.changedTouches[0];
+            if (t) onDragStart(t.clientX, t.clientY, t.identifier);
+        }, { passive: false });
+        tbHit.addEventListener('touchmove', e => {
+            e.preventDefault();
+            for (const t of e.changedTouches) {
+                if (t.identifier === drag.id) {
+                    onDragMove(t.clientX, t.clientY); break;
+                }
+            }
+        }, { passive: false });
+        tbHit.addEventListener('touchend', e => { e.preventDefault(); onDragEnd(); },
+            { passive: false });
+        tbHit.addEventListener('touchcancel', () => onDragEnd());
+        tbHit.addEventListener('mousedown', e => onDragStart(e.clientX, e.clientY, -1));
+        tbHit.addEventListener('mousemove', e => onDragMove(e.clientX, e.clientY));
+        tbHit.addEventListener('mouseup', () => onDragEnd());
+        tbHit.addEventListener('mouseleave', () => onDragEnd());
+
+        // ════════════════════════════════════════════════════════
+        //  J. WATER SPLASH effect
+        // ════════════════════════════════════════════════════════
+        // Drie expanderende witte ringen op het water-niveau als
+        // visuele "plons" wanneer de bal in zee terecht komt.
+        const splashRings = [];
+        function createSplash(x, z) {
+            for (let i = 0; i < 3; i++) {
+                const ringGeo = new THREE.RingGeometry(0.1, 0.18, 24);
+                const ringMat = new THREE.MeshBasicMaterial({
+                    color: 0xffffff, transparent: true, opacity: 0.85,
+                    side: THREE.DoubleSide });
+                const ring = new THREE.Mesh(ringGeo, ringMat);
+                ring.rotation.x = -Math.PI / 2;
+                ring.position.set(x, WATER_Y + 0.06, z);
+                ring.userData.startT = performance.now() / 1000;
+                ring.userData.delay = i * 0.12;
+                scene.add(ring);
+                splashRings.push(ring);
+            }
+        }
+        function updateSplashRings(t) {
+            for (let i = splashRings.length - 1; i >= 0; i--) {
+                const r = splashRings[i];
+                const elapsed = (t - r.userData.startT) - r.userData.delay;
+                if (elapsed < 0) continue;
+                if (elapsed > 1.6) {
+                    scene.remove(r);
+                    r.geometry.dispose(); r.material.dispose();
+                    splashRings.splice(i, 1);
+                    continue;
+                }
+                const s = 1 + elapsed * 5;
+                r.scale.set(s, s, s);
+                r.material.opacity = Math.max(0, 0.85 * (1 - elapsed / 1.6));
+            }
+        }
+
+        // ════════════════════════════════════════════════════════
+        //  K. ANIMATIE-HOOK
+        // ════════════════════════════════════════════════════════
+        function disposeMesh(m) {
+            if (!m) return;
+            m.geometry && m.geometry.dispose && m.geometry.dispose();
+            if (m.material) {
+                const ms = Array.isArray(m.material) ? m.material : [m.material];
+                for (const mat of ms) mat.dispose && mat.dispose();
+            }
+        }
+        function disposeGroup(g) { g.traverse(o => disposeMesh(o)); }
+
+        const PREV_HOOK = window.__deGameHook;
+        let lastT = 0;
+        window.__deGameHook = (time) => {
+            const dt = lastT ? Math.min(0.05, time - lastT) : 0;
+            lastT = time;
+            phaseT += dt;
+            // Splash-ring updates
+            updateSplashRings(time);
+            // Camera tracking — afhankelijk van fase
+            //   1. Entry-lerp: gewone smooth lerp van startpositie naar
+            //      CAM_BOWL (gebruikt camLerpT zoals voorheen).
+            //   2. Rolling: camera VOLGT de bal — positie en target
+            //      lerpen elke frame naar de bal-relatieve positie.
+            //      Lerp-rate is dt * 3.0 zoals in de oude app.
+            //   3. Result_wait: korte zoom op pin-cam zodat impact
+            //      duidelijk wordt, dan terug naar CAM_BOWL voor
+            //      volgende worp.
+            if (camLerpT < 1) {
