+            drag.lastT = performance.now();
+            drag.samples.push({ x: cx, y: cy, t: drag.lastT });
+            if (drag.samples.length > 20) drag.samples.shift();
+            const params = computeDragParams();
+            updatePowerMeter(Math.max(0.20, params.power));
+            buildAimArrow(Math.max(0.20, params.power),
+                params.aimAngle, params.spin, true);
+        }
+        function onDragEnd() {
